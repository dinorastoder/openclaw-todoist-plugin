{
  "id": "todoist",
  "name": "openclaw-todoist-plugin",
  "description": "Todoist integration for OpenClaw via the Todoist REST API. Enables your AI assistant to manage tasks, projects, and labels in Todoist.",
  "version": "1.0.0",
  "skills": [
    "./skills"
  ],
  "contracts": {
    "tools": [
      "todoist_today",
      "todoist_inbox",
      "todoist_add_task",
      "todoist_complete_task",
      "todoist_list_projects",
      "todoist_get_task",
      "todoist_get_tasks",
      "todoist_update_task",
      "todoist_delete_task",
      "todoist_reopen_task",
      "todoist_move_task",
      "todoist_add_project",
      "todoist_update_project",
      "todoist_delete_project",
      "todoist_list_sections",
      "todoist_add_section",
      "todoist_update_section",
      "todoist_delete_section",
      "todoist_list_labels",
      "todoist_add_label",
      "todoist_update_label",
      "todoist_delete_label",
      "todoist_get_comments",
      "todoist_add_comment"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiToken": {
        "type": "string",
        "description": "Todoist API token. Takes priority over the TODOIST_API_TOKEN environment variable."
      }
    }
  },
  "uiHints": {
    "apiToken": {
      "label": "API Token",
      "help": "Your Todoist API token from Settings > Integrations > Developer. Leave empty to use the TODOIST_API_TOKEN environment variable.",
      "sensitive": true
    }
  }
}
